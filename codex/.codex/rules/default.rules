prefix_rule(pattern=["python3", "/Users/azhou@column.com/column/eng-24580-biz-day-roll/.agents/skills/linear-cli/scripts/linear_cli.py", "issue", "get"], decision="allow")
prefix_rule(pattern=["bash", ".agents/skills/query-database/scripts/query.sh", "SELECT JSON_LENGTH(history) AS snapshot_count, COUNT(*) AS config_count FROM interest_configs WHERE removed_at IS NULL GROUP BY JSON_LENGTH(history) ORDER BY snapshot_count"], decision="allow")
prefix_rule(pattern=["bash", ".agents/skills/query-database/scripts/query.sh", "SELECT COUNT(*) AS total_configs, AVG(JSON_LENGTH(history)) AS avg_snapshots, MIN(JSON_LENGTH(history)) AS min_snapshots, MAX(JSON_LENGTH(history)) AS max_snapshots FROM interest_configs WHERE removed_at IS NULL"], decision="allow")
prefix_rule(pattern=["bash", ".agents/skills/query-database/scripts/query.sh", "WITH ordered AS (SELECT JSON_LENGTH(history) AS snapshot_count FROM interest_configs WHERE removed_at IS NULL ORDER BY snapshot_count), numbered AS (SELECT snapshot_count, ROW_NUMBER() OVER (ORDER BY snapshot_count) AS rn, COUNT(*) OVER () AS n FROM ordered) SELECT MIN(CASE WHEN rn >= FLOOR((n + 1) / 2) THEN snapshot_count END) AS p50_snapshot_count, MIN(CASE WHEN rn >= CEIL(n * 0.90) THEN snapshot_count END) AS p90_snapshot_count, MIN(CASE WHEN rn >= CEIL(n * 0.95) THEN snapshot_count END) AS p95_snapshot_count FROM numbered"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "ENV=test GOCACHE=/tmp/go-build go test ./app/internalapi/service/interests -run 'TestForfeit(Column|Both)InterestGin_ManualPayout' -count=1"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "ENV=test GOCACHE=/tmp/go-build go test ./pkg/accounts/interests -run TestNoPayoutIfOtherPayoutUnderReview -count=1"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "ENV=test GOCACHE=/tmp/go-build go test ./pkg/accounts/interests -run '^TestNoPayoutIfOtherPayoutUnderReview$' -count=1"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "ENV=test GOCACHE=/tmp/go-build go test ./pkg/interests -run 'Test(UpdatePayoutStatus_ManualPayoutSkipsInterestLedger|GetMonthlyPayoutsByProductsAndAccruedDate_ExcludesManual)$' -count=1"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "curl -s -H \"Authorization: Bearer ${SLACK_BOT_TOKEN}\" \"https://slack.com/api/conversations.replies?channel=C0291K04RGD&ts=1771280480.905549\" | jq '{ok, error, messages: [.messages[]? | {ts, user, text}]}'"], decision="allow")
