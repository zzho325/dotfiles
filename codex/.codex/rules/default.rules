prefix_rule(pattern=["python3", "/Users/azhou@column.com/column/lms-best-egg/.agents/skills/linear-cli/scripts/linear_cli.py", "issue", "create"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "ENV=test GOCACHE=/tmp/go-build go test ./app/internalapi/service/accounts -run TestUpdateAccountNumber -count=1"], decision="allow")
